# Copy to .env.local

# Canonical site URL for sitemap, Open Graph, and JSON-LD (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://rahulfitzz.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ADMIN_EMAILS=your@gmail.com,collab@rahulfitzz.com
ADMIN_USERNAME=rahulfitzz_admin
ADMIN_PASSWORD=change-me-before-demo

# --- AI coach ---
# Prefer Xiaomi MiMo Token Plan (OpenAI-compatible, no GCP billing):
AI_PROVIDER=auto
MIMO_API_KEY=
MIMO_API_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_MODEL_ID=mimo-v2.5

# Google fallback (optional):
# AI_PROVIDER=google
# GEMINI_API_KEY=          # https://aistudio.google.com/apikey (AIza...)
# GOOGLE_GENAI_USE_VERTEXAI=false
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_API_KEY=
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GEMINI_MODEL_ID=gemini-2.5-flash

# Vercel Analytics: no env vars needed. After deploy, enable Web Analytics in the Vercel project dashboard.

# Optional: email users when an IG claim is approved (Gmail app password works)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
PREBOOK_NOTIFY_EMAIL=collab@rahulfitzz.com

# Vercel Cron: generate a random secret; Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Web Push (background notifications when app is closed)
# Generate once: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@rahulfitzz.com
# Local push testing: ENABLE_PWA_DEV=true then restart npm run dev (service worker required)
ENABLE_PWA_DEV=
